rue"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="text"><shadow type="text" id=".yk:eHGU./MS2Y:~-.RG"><field name="TEXT">You aren't even human. You are the fidget spinner.</field></shadow></value><value name="x"><shadow type="math_number" id="C:gz,O(D2_i1f;IwhIC+"><field name="NUM">80</field></shadow></value><value name="y"><shadow type="math_number" id="Zm])*/%xrhW#tOx`A+D="><field name="NUM">90</field></shadow></value><value name="width"><shadow type="math_number" id="T~F#drDP/2-S]qs/N5p?"><field name="NUM">150</field></shadow></value><value name="height"><shadow type="math_number" id="992C#+@1+Yw:T+#%vNO^"><field name="NUM">50</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id="1s2:=.nVrmC+=t|L.*}9"><field name="index">15</field></shadow></value><value name="background"><shadow type="colorindexpicker" id="(m_VT.WA,lWNuUKLiJgt"><field name="index">1</field></shadow></value><next><block type="device_pause" id="eBAM=q:i2,wD)BlKaI`v"><value name="pause"><shadow type="timePicker" id="i]8G@C2b_VZR,R.g{S@4"><field name="ms">500</field></shadow></value><next><block type="story_print_dialog" id="/$@oIIGK,z*gh}ksHK;q"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="text"><shadow type="text" id="bVAVKI^9=O,@Rw6415jf"><field name="TEXT">This game is about society.</field></shadow></value><value name="x"><shadow type="math_number" id="Jn+^)?T2{j.IT(NXliyX"><field name="NUM">80</field></shadow></value><value name="y"><shadow type="math_number" id=")ge{]{bxnxkG@]%y{+Rc"><field name="NUM">90</field></shadow></value><value name="width"><shadow type="math_number" id="l^7[R@8#Eav,SQ-R+S.j"><field name="NUM">150</field></shadow></value><value name="height"><shadow type="math_number" id="iu!xDRb%db%r`BZ;`HVf"><field name="NUM">50</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id="~